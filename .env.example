PORT=3000
NODE_ENV=development
DEV_BYPASS_AUTH=false
SESSION_SECRET=replace-with-a-long-random-string

# GHN SSO v2 / OpenID Connect
SSO_BASE_URL=https://dev-online-gateway.ghn.vn/sso-v2/public-api
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:3000/auth/callback
SSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/auth/logout/callback
SSO_REQUEST_TIMEOUT_MS=10000

# Đăng ký thêm URI này trên GHN SSO (production phải dùng HTTPS):
# backchannel_logout_uri=http://localhost:3000/auth/backchannel-logout

# GTalk
GTALK_BASE_URL=https://test-api.mbff.ghn.tech
GTALK_USERNAME=
GTALK_PASSWORD=
GTALK_OA_ID=
GTALK_CHANNEL_ID=

ALERT_CRON=30 8 * * *
DASHBOARD_URL=http://localhost:3000
